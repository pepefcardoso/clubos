{
  "name": "clubos",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "db:up": "docker compose up -d",
    "db:migrate": "pnpm --filter api run db:migrate",
    "db:studio": "pnpm --filter api run db:studio",
    "test:e2e": "pnpm --filter=web test:e2e",
    "audit": "pnpm audit --audit-level=high",
    "audit:fix": "pnpm audit --fix"
  },
  "devDependencies": {
    "prettier": "^3.8.1",
    "turbo": "^2.8.16",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  },
  "pnpm": {
    "overrides": {
      "react": "^19",
      "react-dom": "^19",
      "@types/react": "^19",
      "@types/react-dom": "^19",
      "ioredis": "5.10.0"
    },
    "auditConfig": {
      "ignoreCves": []
    }
  }
}
