{
  "name": "clubos",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "db:up": "docker compose up -d",
    "db:migrate": "pnpm --filter api run db:migrate",
    "db:studio": "pnpm --filter api run db:studio",
    "test:e2e": "pnpm --filter=web test:e2e",
    "audit": "pnpm audit --audit-level=high",
    "audit:fix": "pnpm audit --fix"
  },
  "devDependencies": {
    "prettier": "^3.8.1",
    "turbo": "^2.8.16",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  },
  "pnpm": {
    "overrides": {
      "react": "^19",
      "react-dom": "^19",
      "@types/react": "^19",
      "@types/react-dom": "^19",
      "ioredis": "5.10.0",
      "lodash@>=4.0.0 <=4.17.22": ">=4.17.23",
      "hono@<4.11.7": ">=4.11.7",
      "hono@<4.12.4": ">=4.12.4",
      "@hono/node-server@<1.19.10": ">=1.19.10",
      "next@>=16.0.0-beta.0 <16.1.7": ">=16.1.7",
      "next@>=16.0.1 <16.1.7": ">=16.1.7",
      "effect@<3.20.0": ">=3.20.0",
      "flatted@<=3.4.1": ">=3.4.2",
      "fastify@<=5.8.2": ">=5.8.3",
      "brace-expansion@<1.1.13": ">=1.1.13",
      "brace-expansion@>=2.0.0 <2.0.3": ">=2.0.3",
      "brace-expansion@>=4.0.0 <5.0.5": ">=5.0.5",
      "picomatch@<2.3.2": ">=2.3.2",
      "picomatch@>=4.0.0 <4.0.4": ">=4.0.4",
      "lodash@>=4.0.0 <=4.17.23": ">=4.18.0",
      "lodash@<=4.17.23": ">=4.18.0",
      "defu@<=6.1.4": ">=6.1.5",
      "fast-jwt@<=6.1.0": ">=6.2.0",
      "vite@>=7.0.0 <=7.3.1": ">=7.3.2",
      "vite@>=7.1.0 <=7.3.1": ">=7.3.2",
      "fast-jwt@>=0.0.1 <6.2.0": ">=6.2.0",
      "hono@<4.12.12": ">=4.12.12",
      "hono@>=4.0.0 <=4.12.11": ">=4.12.12",
      "@hono/node-server@<1.19.13": ">=1.19.13"
    },
    "auditConfig": {
      "ignoreCves": []
    }
  }
}
