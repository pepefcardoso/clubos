NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_DOMAIN=clubos.com.br
RESEND_API_KEY=your_resend_api_key_here
CONTACT_EMAIL_TO=your_email@clubos.com.br

# ─── Observability ─────────────────────────────────────────────────────────────
# Obtain DSN from Sentry project settings: https://sentry.io/settings/
# Leave blank to disable Sentry.
# NEXT_PUBLIC_SENTRY_DSN is exposed to the browser bundle (this is intentional —
# DSN is a public identifier, not a secret).
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=

# Required only at build time for source-map upload (set as CI/CD secret, not here):
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=clubos
# SENTRY_PROJECT=clubos-web
