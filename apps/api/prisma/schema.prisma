// MULTI-TENANCY STRATEGY: schema-per-tenant
//
//   [PUBLIC SCHEMA] — models that live in the `public` PostgreSQL schema:
//     Club, User
//     These are the tenant registry and global auth tables.
//
//   [TENANT MODELS] — models that represent the structure of each tenant schema
//     (clube_{id}): Member, Plan, MemberPlan, Charge, Payment, Message, AuditLog,
//                   Athlete, Contract, WorkloadMetric, Exercise, TrainingSession,
//                   SessionExercise, InjuryProtocol, MedicalRecord, ReturnToPlay,
//                   DataAccessLog, CreditorDisclosure, FieldAccessLog
//
//     At runtime, before any tenant query the API MUST execute:
//       SET search_path TO "clube_{clubId}", public
//     This is handled by the Prisma middleware in apps/api/src/lib/prisma.ts.
//     Prisma uses these model definitions for full type-safety; the actual
//     table rows live inside the tenant's own PostgreSQL schema.
//
//     Tenant schemas are created during onboarding via raw SQL:
//       CREATE SCHEMA IF NOT EXISTS "clube_{clubId}"
//     followed by running the tenant migrations inside that schema.
//
// PAYMENT GATEWAY ABSTRACTION
//
//   The Charge model is intentionally gateway-agnostic. Provider-specific
//   data (Pix QR code, boleto URL, card checkout link, etc.) is stored in
//   the `gatewayMeta` JSONB column rather than as typed columns.
//
//   This allows adding new gateways (Pagarme, Stripe, etc.) without schema
//   migrations. See apps/api/src/modules/payments/ for the gateway layer.
//
// ENCRYPTION
//
//   Member.cpf, Member.phone, Athlete.cpf are encrypted at rest using
//   PostgreSQL's pgcrypto extension (pgp_sym_encrypt / pgp_sym_decrypt,
//   AES-256). The symmetric key is provided via the MEMBER_ENCRYPTION_KEY
//   env var.
//
//   MedicalRecord.clinicalNotes, .diagnosis, .treatmentDetails are also
//   encrypted at rest using the same pgcrypto AES-256 mechanism.
//
//   Consequences:
//   - Encrypted fields are stored as Bytes (bytea) — never as plaintext.
//   - The @unique constraint on cpf is removed; uniqueness is enforced at
//     the application layer via findMemberByCpf() / findAthleteByCpf() in
//     src/lib/crypto.ts.
//   - All reads/writes of encrypted fields go through encryptField() /
//     decryptField() in src/lib/crypto.ts — never via raw Prisma field access.
// =============================================================================

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  TREASURER
  PHYSIO
}

enum MemberStatus {
  ACTIVE
  INACTIVE
  OVERDUE
}

enum AthleteStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum ContractType {
  PROFESSIONAL
  AMATEUR
  FORMATIVE
  LOAN
}

enum ContractStatus {
  ACTIVE
  EXPIRED
  TERMINATED
  SUSPENDED
}

enum ExpenseCategory {
  SALARY
  FIELD_MAINTENANCE
  EQUIPMENT
  TRAVEL
  ADMINISTRATIVE
  OTHER
}

enum ExerciseCategory {
  STRENGTH
  CARDIO
  TECHNICAL
  TACTICAL
  RECOVERY
  OTHER
}

enum SessionType {
  MATCH
  TRAINING
  GYM
  RECOVERY
  OTHER
}

enum PlanInterval {
  monthly
  quarterly
  annual
}

enum PaymentMethod {
  PIX
  CREDIT_CARD
  DEBIT_CARD
  BOLETO
  CASH
  BANK_TRANSFER
}

enum ChargeStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
  PENDING_RETRY
}

enum MessageChannel {
  WHATSAPP
  EMAIL
}

enum MessageStatus {
  SENT
  FAILED
  PENDING
}

enum RtpStatus {
  AFASTADO
  RETORNO_PROGRESSIVO
  LIBERADO
}

/// FIFA Medical-aligned injury grade classification.
/// GRADE_1 = mild (< 7 days), GRADE_2 = moderate (7–28 days),
/// GRADE_3 = severe (> 28 days), COMPLETE = complete rupture / structural failure.
enum InjuryGrade {
  GRADE_1
  GRADE_2
  GRADE_3
  COMPLETE
}

enum InjuryMechanism {
  CONTACT
  NON_CONTACT
  OVERUSE
  UNKNOWN
}

enum AuditAction {
  MEMBER_CREATED
  MEMBER_UPDATED
  MEMBER_DELETED
  CHARGE_GENERATED
  CHARGE_CANCELLED
  PAYMENT_CONFIRMED
  PLAN_CREATED
  PLAN_UPDATED
  PLAN_DELETED
  MESSAGE_SENT
  ATHLETE_CREATED
  ATHLETE_UPDATED
  ATHLETE_DELETED
  CONTRACT_CREATED
  CONTRACT_UPDATED
  CONTRACT_TERMINATED
  LOGIN_SUCCESS
  LOGIN_FAILED
  LOGIN_LOCKED
  EXPENSE_CREATED
  EXPENSE_UPDATED
  EXPENSE_DELETED
  BALANCE_SHEET_PUBLISHED
  TEMPLATE_UPDATED
  TEMPLATE_RESET
  EXERCISE_CREATED
  EXERCISE_UPDATED
  EXERCISE_DELETED
  TRAINING_SESSION_CREATED
  TRAINING_SESSION_UPDATED
  TRAINING_SESSION_DELETED
  EVALUATION_CREATED
  EVALUATION_UPDATED
  EVALUATION_DELETED
  PARENTAL_CONSENT_RECORDED
  WEEKLY_ATHLETE_REPORT_SENT
  MEDICAL_RECORD_CREATED
  MEDICAL_RECORD_UPDATED
  MEDICAL_RECORD_ACCESSED
  RTP_STATUS_CHANGED
  CREDITOR_DISCLOSURE_CREATED
  CREDITOR_DISCLOSURE_UPDATED
  FIELD_ACCESS_LOGGED
}

/// Tenant registry. Each Club corresponds to one PostgreSQL schema: clube_{id}.
/// The slug is used both in URLs and as part of the schema name.
model Club {
  id             String   @id @default(cuid())
  slug           String   @unique
  name           String
  logoUrl        String?
  cnpj           String?  @unique
  planTier       String   @default("starter")
  /// Static Pix key used as last-resort fallback when all payment gateways fail.
  /// Supported formats: CPF, CNPJ, phone (+5511999990000), e-mail, or random UUID key.
  /// Null means no static fallback is configured — all gateway failures will be retried by BullMQ.
  pixKeyFallback String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  users User[]

  @@map("clubs")
}

/// Global users table (public schema). A user always belongs to one club.
/// Roles: ADMIN (full access) | TREASURER (read + charge, no delete/settings)
///        | PHYSIO (clinical data access, no financial access).
model User {
  id       String   @id @default(cuid())
  email    String   @unique
  password String // bcrypt hash
  role     UserRole @default(TREASURER)
  clubId   String

  club Club @relation(fields: [clubId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clubId])
  @@map("users")
}

// =============================================================================
// TENANT SCHEMA MODELS — live inside clube_{id} PostgreSQL schemas
// =============================================================================

model Member {
  id        String       @id @default(cuid())
  name      String
  cpf       Bytes
  phone     Bytes
  email     String?
  status    MemberStatus @default(ACTIVE)
  joinedAt  DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  plans     MemberPlan[]
  charges   Charge[]
  messages  Message[]
  auditLogs AuditLog[]

  @@index([status])
  @@map("members")
}

model Plan {
  id         String       @id @default(cuid())
  name       String
  priceCents Int
  interval   PlanInterval @default(monthly)
  benefits   String[]
  isActive   Boolean      @default(true)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  members MemberPlan[]

  @@map("plans")
}

model MemberPlan {
  id        String    @id @default(cuid())
  memberId  String
  planId    String
  startedAt DateTime  @default(now())
  endedAt   DateTime?

  member Member @relation(fields: [memberId], references: [id])
  plan   Plan   @relation(fields: [planId], references: [id])

  @@unique([memberId, planId])
  @@index([planId])
  @@map("member_plans")
}

/// Gateway fields:
///   method      → what payment method was requested (PIX, CARD, CASH, …)
///   gatewayName → which provider handled it ("asaas", "pagarme", "stripe", null for offline/static-pix)
///   externalId  → charge ID in the external gateway (used for cancellation / lookup)
///   gatewayMeta → provider + method-specific data stored as JSONB, e.g.:
///                   PIX (Asaas/Pagarme) → { qrCodeBase64, pixCopyPaste }
///                   PIX (Stripe)        → { pixCopyPaste, qrCodeUrl, paymentIntentId }
///                     NOTE: Stripe serves the QR as a hosted PNG URL, not inline base64.
///                     Frontend must branch on charges.gatewayName:
///                       "asaas"/"pagarme" → <img src="data:image/png;base64,{qrCodeBase64}"/>
///                       "stripe"          → <img src={qrCodeUrl}/> or display pixCopyPaste
///                   Boleto→ { bankSlipUrl, pdfUrl }
///                   Card  → { checkoutUrl }
///                   Cash  → {}  (no external data)
///                   Static PIX → { type: "static_pix", pixKey: "..." }
model Charge {
  id          String        @id @default(cuid())
  memberId    String
  amountCents Int
  dueDate     DateTime
  status      ChargeStatus  @default(PENDING)
  method      PaymentMethod @default(PIX)
  gatewayName String?
  externalId  String?
  gatewayMeta Json?
  retryCount  Int           @default(0)
  lastRetryAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  member  Member   @relation(fields: [memberId], references: [id])
  payment Payment?

  @@index([memberId])
  @@index([status])
  @@index([dueDate])
  @@index([gatewayName])
  @@map("charges")
}

model Payment {
  id           String        @id @default(cuid())
  chargeId     String        @unique
  paidAt       DateTime
  method       PaymentMethod
  amountCents  Int
  gatewayTxid  String        @unique
  cancelledAt  DateTime?
  cancelReason String?
  createdAt    DateTime      @default(now())

  charge Charge @relation(fields: [chargeId], references: [id])

  @@index([gatewayTxid])
  @@map("payments")
}

model Message {
  id         String         @id @default(cuid())
  memberId   String
  channel    MessageChannel
  template   String
  status     MessageStatus  @default(PENDING)
  sentAt     DateTime?
  failReason String?
  createdAt  DateTime       @default(now())

  member Member @relation(fields: [memberId], references: [id])

  @@index([memberId])
  @@index([status])
  @@map("messages")
}

model MessageTemplate {
  id        String         @id @default(cuid())
  key       String
  channel   MessageChannel @default(WHATSAPP)
  body      String
  isActive  Boolean        @default(true)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@unique([key, channel])
  @@index([key])
  @@map("message_templates")
}

model AuditLog {
  id         String      @id @default(cuid())
  memberId   String?
  actorId    String?
  action     AuditAction
  entityId   String?
  entityType String?
  metadata   Json?
  createdAt  DateTime    @default(now())

  member Member? @relation(fields: [memberId], references: [id])

  @@index([action])
  @@index([memberId])
  @@index([createdAt])
  @@map("audit_log")
}

model Athlete {
  id        String        @id @default(cuid())
  name      String
  cpf       Bytes
  birthDate DateTime      @db.Date
  position  String?
  status    AthleteStatus @default(ACTIVE)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  contracts         Contract[]
  workloadMetrics   WorkloadMetric[]
  integrationTokens IntegrationToken[]
  evaluations       TechnicalEvaluation[]
  medicalRecords    MedicalRecord[]
  returnToPlay      ReturnToPlay?

  @@index([status])
  @@map("athletes")
}

model Contract {
  id             String         @id @default(cuid())
  athleteId      String
  type           ContractType
  status         ContractStatus @default(ACTIVE)
  startDate      DateTime       @db.Date
  endDate        DateTime?      @db.Date
  bidRegistered  Boolean        @default(false)
  federationCode String?
  notes          String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  athlete Athlete @relation(fields: [athleteId], references: [id])

  @@index([athleteId])
  @@index([status])
  @@index([endDate])
  @@map("contracts")
}

model WorkloadMetric {
  id                String      @id @default(cuid())
  athleteId         String
  trainingSessionId String?
  date              DateTime    @db.Date
  rpe               Int
  durationMinutes   Int
  sessionType       SessionType @default(TRAINING)
  notes             String?
  idempotencyKey    String?     @unique
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  athlete         Athlete          @relation(fields: [athleteId], references: [id])
  trainingSession TrainingSession? @relation(fields: [trainingSessionId], references: [id])

  @@index([athleteId])
  @@index([date])
  @@map("workload_metrics")
}

model RulesConfig {
  id        String   @id @default(cuid())
  season    String
  league    String
  rules     Json
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([season, league])
  @@index([isActive])
  @@map("rules_config")
}

model Expense {
  id          String          @id @default(cuid())
  description String
  amountCents Int
  category    ExpenseCategory @default(OTHER)
  date        DateTime        @db.Date
  notes       String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([date])
  @@index([category])
  @@map("expenses")
}

/// Published SAF financial balance sheets.
/// Stored in the tenant schema (clube_{id}).
///
/// IMMUTABLE — no UPDATE or DELETE is ever issued against this table.
/// Deletion is structurally forbidden by the application (Lei 14.193/2021).
///
/// fileHash stores the SHA-256 hex digest of the original PDF bytes, allowing
/// anyone to verify the document was not tampered with after publication.
model BalanceSheet {
  id          String   @id @default(cuid())
  title       String
  period      String
  fileUrl     String
  fileHash    String
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([publishedAt])
  @@map("balance_sheets")
}

model Exercise {
  id           String           @id @default(cuid())
  name         String
  description  String?
  category     ExerciseCategory @default(OTHER)
  muscleGroups String[]
  isActive     Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  sessionExercises SessionExercise[]

  @@index([category])
  @@index([isActive])
  @@map("exercises")
}

model TrainingSession {
  id              String      @id @default(cuid())
  title           String
  scheduledAt     DateTime
  sessionType     SessionType @default(TRAINING)
  durationMinutes Int
  notes           String?
  isCompleted     Boolean     @default(false)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  sessionExercises SessionExercise[]
  workloadMetrics  WorkloadMetric[]

  @@index([scheduledAt])
  @@index([sessionType])
  @@index([isCompleted])
  @@map("training_sessions")
}

model SessionExercise {
  id                String  @id @default(cuid())
  trainingSessionId String
  exerciseId        String
  order             Int     @default(0)
  sets              Int?
  reps              Int?
  durationSeconds   Int?
  notes             String?

  trainingSession TrainingSession @relation(fields: [trainingSessionId], references: [id])
  exercise        Exercise        @relation(fields: [exerciseId], references: [id])

  @@unique([trainingSessionId, exerciseId])
  @@index([trainingSessionId])
  @@index([exerciseId])
  @@map("session_exercises")
}

model IntegrationToken {
  id         String    @id @default(cuid())
  athleteId  String
  tokenHash  String
  label      String
  isActive   Boolean   @default(true)
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  athlete Athlete @relation(fields: [athleteId], references: [id])

  @@index([athleteId])
  @@index([isActive])
  @@map("integration_tokens")
}

model TechnicalEvaluation {
  id         String   @id @default(cuid())
  athleteId  String
  microcycle String
  date       DateTime @db.Date
  technique  Int
  tactical   Int
  physical   Int
  mental     Int
  attitude   Int
  notes      String?
  actorId    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  athlete Athlete @relation(fields: [athleteId], references: [id])

  @@unique([athleteId, microcycle])
  @@index([athleteId])
  @@index([date])
  @@map("technical_evaluations")
}

/// Reference/seed table for injury return-to-play protocols.
/// Seeded with FIFA Medical standard protocols (20 protocols covering the most
/// common football injuries). Club-level — not per-athlete.
/// isActive=false soft-deletes a protocol without breaking existing references.
model InjuryProtocol {
  id           String      @id @default(cuid())
  name         String
  structure    String
  grade        InjuryGrade
  steps        Json        @default("[]")
  source       String?
  durationDays Int         @default(0)
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  medicalRecords MedicalRecord[]
  returnToPlay   ReturnToPlay[]

  @@index([structure])
  @@index([isActive])
  @@map("injury_protocols")
}

/// Athlete medical record (prontuário esportivo).
/// Access restricted to PHYSIO and ADMIN roles at the API layer.
///
/// ENCRYPTION: clinicalNotes, diagnosis, treatmentDetails are stored as BYTEA
/// (AES-256 via pgcrypto). Never read raw — always use decryptField() in src/lib/crypto.ts.
///
/// Fields kept as plaintext for analytics (ACWR correlation query):
///   structure, grade, mechanism — queried without decryption by the physio dashboard.
///
/// createdBy stores the PHYSIO actorId for accountability and LGPD audit.
model MedicalRecord {
  id               String          @id @default(cuid())
  athleteId        String
  protocolId       String?
  occurredAt       DateTime        @db.Date
  structure        String
  grade            InjuryGrade
  mechanism        InjuryMechanism @default(UNKNOWN)
  /// AES-256 encrypted via pgcrypto — never read raw; use decryptField()
  clinicalNotes    Bytes?
  /// AES-256 encrypted via pgcrypto — never read raw; use decryptField()
  diagnosis        Bytes?
  /// AES-256 encrypted via pgcrypto — never read raw; use decryptField()
  treatmentDetails Bytes?
  createdBy        String
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  athlete      Athlete         @relation(fields: [athleteId], references: [id])
  protocol     InjuryProtocol? @relation(fields: [protocolId], references: [id])
  returnToPlay ReturnToPlay[]

  @@index([athleteId])
  @@index([occurredAt])
  @@index([grade])
  @@map("medical_records")
}

/// Return-to-play (RTP) status per athlete.
/// One record per athlete (UNIQUE on athleteId) — updated in-place as status changes.
/// Status transitions: AFASTADO → RETORNO_PROGRESSIVO → LIBERADO (and back).
/// clearedAt/clearedBy populated when status transitions to LIBERADO.
/// medicalRecordId is nullable — RTP may predate a formal medical record.
model ReturnToPlay {
  id              String    @id @default(cuid())
  athleteId       String    @unique
  status          RtpStatus @default(AFASTADO)
  medicalRecordId String?
  protocolId      String?
  clearedAt       DateTime?
  clearedBy       String?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  athlete       Athlete         @relation(fields: [athleteId], references: [id])
  medicalRecord MedicalRecord?  @relation(fields: [medicalRecordId], references: [id])
  protocol      InjuryProtocol? @relation(fields: [protocolId], references: [id])

  @@index([status])
  @@map("return_to_play")
}

/// LGPD compliance audit log for clinical data access (Art. 37 — registro de operações).
///
/// Intentionally NO foreign key to medical_records: the clinical record may be
/// purged under LGPD Art. 15 / Art. 16 while access logs must be retained.
/// entityId stores medical_records.id; entityType defaults to 'MedicalRecord'.
/// fieldsRead lists which encrypted fields were decrypted, e.g. ['clinicalNotes'].
/// action is TEXT (not the AuditAction enum) so the vocabulary can evolve
/// independently — e.g. "READ", "EXPORT_PDF", "SHARED_WITH_INSURER".
model DataAccessLog {
  id         String   @id @default(cuid())
  actorId    String
  entityId   String
  entityType String   @default("MedicalRecord")
  action     String
  fieldsRead String[]
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([actorId])
  @@index([entityId])
  @@map("data_access_log")
}

/// SAF compliance — Lei 14.193/2021 creditor disclosures (passivos trabalhistas).
///
/// APPEND-ONLY: the application layer prohibits DELETE on this table.
/// Status transitions (PENDING → SETTLED | DISPUTED) are the only mutations allowed.
/// status is TEXT to allow future values without a DDL migration.
/// registeredBy stores the ADMIN actorId who registered the liability.
model CreditorDisclosure {
  id           String   @id @default(cuid())
  creditorName String
  description  String?
  amountCents  Int
  dueDate      DateTime @db.Date
  /// PENDING | SETTLED | DISPUTED
  status       String   @default("PENDING")
  registeredBy String
  registeredAt DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([dueDate])
  @@index([status])
  @@map("creditor_disclosures")
}

/// QR Code portaria access control log.
///
/// No FK to members (ticket holder may not be a registered member).
/// No FK to events — eventId is TEXT nullable; the events table arrives in v2.5.
/// idempotencyKey supports offline Background Sync deduplication, consistent
/// with workload_metrics.idempotencyKey. Partial unique index in DDL:
///   WHERE idempotencyKey IS NOT NULL.
model FieldAccessLog {
  id              String   @id @default(cuid())
  eventId         String?
  scannedBy       String
  payload         String
  isValid         Boolean
  rejectionReason String?
  idempotencyKey  String?  @unique
  scannedAt       DateTime @default(now())
  createdAt       DateTime @default(now())

  @@map("field_access_logs")
}
