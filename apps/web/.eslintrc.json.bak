{
  "extends": ["next/core-web-vitals", "next/typescript"],
  "rules": {
    "import/no-restricted-paths": [
      "error",
      {
        "zones": [
          {
            "target": "./src/app/(marketing)",
            "from": "./src/app/(app)",
            "message": "(marketing) must not import from (app). Move shared code to src/components/ instead."
          }
        ]
      }
    ]
  }
}
