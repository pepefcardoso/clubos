// MULTI-TENANCY STRATEGY: schema-per-tenant
//
//   [PUBLIC SCHEMA] — Club, User
//   [TENANT MODELS] — all others, live in clube_{id} schema
//
// See original file header for full design notes.
// v2.5 additions: Event, EventSector, Ticket, FanProfile, PosSale, GameChecklist

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  TREASURER
  PHYSIO
}

enum MemberStatus {
  ACTIVE
  INACTIVE
  OVERDUE
}

enum AthleteStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum ContractType {
  PROFESSIONAL
  AMATEUR
  FORMATIVE
  LOAN
}

enum ContractStatus {
  ACTIVE
  EXPIRED
  TERMINATED
  SUSPENDED
}

enum ExpenseCategory {
  SALARY
  FIELD_MAINTENANCE
  EQUIPMENT
  TRAVEL
  ADMINISTRATIVE
  OTHER
}

enum ExerciseCategory {
  STRENGTH
  CARDIO
  TECHNICAL
  TACTICAL
  RECOVERY
  OTHER
}

enum SessionType {
  MATCH
  TRAINING
  GYM
  RECOVERY
  OTHER
}

enum PlanInterval {
  monthly
  quarterly
  annual
}

enum PaymentMethod {
  PIX
  CREDIT_CARD
  DEBIT_CARD
  BOLETO
  CASH
  BANK_TRANSFER
}

enum ChargeStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
  PENDING_RETRY
}

enum MessageChannel {
  WHATSAPP
  EMAIL
}

enum MessageStatus {
  SENT
  FAILED
  PENDING
}

enum RtpStatus {
  AFASTADO
  RETORNO_PROGRESSIVO
  LIBERADO
}

/// FIFA Medical-aligned injury grade classification.
enum InjuryGrade {
  GRADE_1
  GRADE_2
  GRADE_3
  COMPLETE
}

enum InjuryMechanism {
  CONTACT
  NON_CONTACT
  OVERUSE
  UNKNOWN
}

enum EventStatus {
  SCHEDULED
  LIVE
  COMPLETED
  CANCELLED
}

enum TicketStatus {
  PENDING
  PAID
  CANCELLED
  CHECKED_IN
}

enum AuditAction {
  MEMBER_CREATED
  MEMBER_UPDATED
  MEMBER_DELETED
  CHARGE_GENERATED
  CHARGE_CANCELLED
  PAYMENT_CONFIRMED
  PLAN_CREATED
  PLAN_UPDATED
  PLAN_DELETED
  MESSAGE_SENT
  ATHLETE_CREATED
  ATHLETE_UPDATED
  ATHLETE_DELETED
  CONTRACT_CREATED
  CONTRACT_UPDATED
  CONTRACT_TERMINATED
  LOGIN_SUCCESS
  LOGIN_FAILED
  LOGIN_LOCKED
  EXPENSE_CREATED
  EXPENSE_UPDATED
  EXPENSE_DELETED
  BALANCE_SHEET_PUBLISHED
  TEMPLATE_UPDATED
  TEMPLATE_RESET
  EXERCISE_CREATED
  EXERCISE_UPDATED
  EXERCISE_DELETED
  TRAINING_SESSION_CREATED
  TRAINING_SESSION_UPDATED
  TRAINING_SESSION_DELETED
  EVALUATION_CREATED
  EVALUATION_UPDATED
  EVALUATION_DELETED
  PARENTAL_CONSENT_RECORDED
  WEEKLY_ATHLETE_REPORT_SENT
  MEDICAL_RECORD_CREATED
  MEDICAL_RECORD_UPDATED
  MEDICAL_RECORD_ACCESSED
  RTP_STATUS_CHANGED
  CREDITOR_DISCLOSURE_CREATED
  CREDITOR_DISCLOSURE_UPDATED
  FIELD_ACCESS_LOGGED
  MEDICAL_RECORD_TRANSFER_OUT
  MEDICAL_RECORD_TRANSFER_IN
}

/// Tenant registry. Each Club corresponds to one PostgreSQL schema: clube_{id}.
model Club {
  id             String   @id @default(cuid())
  slug           String   @unique
  name           String
  logoUrl        String?
  cnpj           String?  @unique
  planTier       String   @default("starter")
  pixKeyFallback String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  users              User[]
  physioClubAccesses PhysioClubAccess[]

  @@map("clubs")
}

model User {
  id       String   @id @default(cuid())
  email    String   @unique
  password String
  role     UserRole @default(TREASURER)
  clubId   String

  club Club @relation(fields: [clubId], references: [id])

  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  physioClubAccesses PhysioClubAccess[]

  @@index([clubId])
  @@map("users")
}

// =============================================================================
// TENANT SCHEMA MODELS
// =============================================================================

model Member {
  id        String       @id @default(cuid())
  name      String
  cpf       Bytes
  phone     Bytes
  email     String?
  status    MemberStatus @default(ACTIVE)
  joinedAt  DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  plans     MemberPlan[]
  charges   Charge[]
  messages  Message[]
  auditLogs AuditLog[]

  @@index([status])
  @@map("members")
}

model Plan {
  id         String       @id @default(cuid())
  name       String
  priceCents Int
  interval   PlanInterval @default(monthly)
  benefits   String[]
  isActive   Boolean      @default(true)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  members MemberPlan[]

  @@map("plans")
}

model MemberPlan {
  id        String    @id @default(cuid())
  memberId  String
  planId    String
  startedAt DateTime  @default(now())
  endedAt   DateTime?

  member Member @relation(fields: [memberId], references: [id])
  plan   Plan   @relation(fields: [planId], references: [id])

  @@unique([memberId, planId])
  @@index([planId])
  @@map("member_plans")
}

model Charge {
  id          String        @id @default(cuid())
  memberId    String
  amountCents Int
  dueDate     DateTime
  status      ChargeStatus  @default(PENDING)
  method      PaymentMethod @default(PIX)
  gatewayName String?
  externalId  String?
  gatewayMeta Json?
  retryCount  Int           @default(0)
  lastRetryAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  member  Member   @relation(fields: [memberId], references: [id])
  payment Payment?

  @@index([memberId])
  @@index([status])
  @@index([dueDate])
  @@index([gatewayName])
  @@map("charges")
}

model Payment {
  id           String        @id @default(cuid())
  chargeId     String        @unique
  paidAt       DateTime
  method       PaymentMethod
  amountCents  Int
  gatewayTxid  String        @unique
  cancelledAt  DateTime?
  cancelReason String?
  createdAt    DateTime      @default(now())

  charge Charge @relation(fields: [chargeId], references: [id])

  @@index([gatewayTxid])
  @@map("payments")
}

model Message {
  id         String         @id @default(cuid())
  memberId   String
  channel    MessageChannel
  template   String
  status     MessageStatus  @default(PENDING)
  sentAt     DateTime?
  failReason String?
  createdAt  DateTime       @default(now())

  member Member @relation(fields: [memberId], references: [id])

  @@index([memberId])
  @@index([status])
  @@map("messages")
}

model MessageTemplate {
  id        String         @id @default(cuid())
  key       String
  channel   MessageChannel @default(WHATSAPP)
  body      String
  isActive  Boolean        @default(true)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@unique([key, channel])
  @@index([key])
  @@map("message_templates")
}

model AuditLog {
  id         String      @id @default(cuid())
  memberId   String?
  actorId    String?
  action     AuditAction
  entityId   String?
  entityType String?
  metadata   Json?
  createdAt  DateTime    @default(now())

  member Member? @relation(fields: [memberId], references: [id])

  @@index([action])
  @@index([memberId])
  @@index([createdAt])
  @@map("audit_log")
}

model Athlete {
  id        String        @id @default(cuid())
  name      String
  cpf       Bytes
  birthDate DateTime      @db.Date
  position  String?
  status    AthleteStatus @default(ACTIVE)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  contracts         Contract[]
  workloadMetrics   WorkloadMetric[]
  integrationTokens IntegrationToken[]
  evaluations       TechnicalEvaluation[]
  medicalRecords    MedicalRecord[]
  returnToPlay      ReturnToPlay?

  @@index([status])
  @@map("athletes")
}

model Contract {
  id             String         @id @default(cuid())
  athleteId      String
  type           ContractType
  status         ContractStatus @default(ACTIVE)
  startDate      DateTime       @db.Date
  endDate        DateTime?      @db.Date
  bidRegistered  Boolean        @default(false)
  federationCode String?
  notes          String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  athlete Athlete @relation(fields: [athleteId], references: [id])

  @@index([athleteId])
  @@index([status])
  @@index([endDate])
  @@map("contracts")
}

model WorkloadMetric {
  id                String      @id @default(cuid())
  athleteId         String
  trainingSessionId String?
  date              DateTime    @db.Date
  rpe               Int
  durationMinutes   Int
  sessionType       SessionType @default(TRAINING)
  notes             String?
  idempotencyKey    String?     @unique
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  athlete         Athlete          @relation(fields: [athleteId], references: [id])
  trainingSession TrainingSession? @relation(fields: [trainingSessionId], references: [id])

  @@index([athleteId])
  @@index([date])
  @@map("workload_metrics")
}

model RulesConfig {
  id        String   @id @default(cuid())
  season    String
  league    String
  rules     Json
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([season, league])
  @@index([isActive])
  @@map("rules_config")
}

model Expense {
  id          String          @id @default(cuid())
  description String
  amountCents Int
  category    ExpenseCategory @default(OTHER)
  date        DateTime        @db.Date
  notes       String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([date])
  @@index([category])
  @@map("expenses")
}

model BalanceSheet {
  id          String   @id @default(cuid())
  title       String
  period      String
  fileUrl     String
  fileHash    String
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([publishedAt])
  @@map("balance_sheets")
}

model Exercise {
  id           String           @id @default(cuid())
  name         String
  description  String?
  category     ExerciseCategory @default(OTHER)
  muscleGroups String[]
  isActive     Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  sessionExercises SessionExercise[]

  @@index([category])
  @@index([isActive])
  @@map("exercises")
}

model TrainingSession {
  id              String      @id @default(cuid())
  title           String
  scheduledAt     DateTime
  sessionType     SessionType @default(TRAINING)
  durationMinutes Int
  notes           String?
  isCompleted     Boolean     @default(false)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  sessionExercises SessionExercise[]
  workloadMetrics  WorkloadMetric[]

  @@index([scheduledAt])
  @@index([sessionType])
  @@index([isCompleted])
  @@map("training_sessions")
}

model SessionExercise {
  id                String  @id @default(cuid())
  trainingSessionId String
  exerciseId        String
  order             Int     @default(0)
  sets              Int?
  reps              Int?
  durationSeconds   Int?
  notes             String?

  trainingSession TrainingSession @relation(fields: [trainingSessionId], references: [id])
  exercise        Exercise        @relation(fields: [exerciseId], references: [id])

  @@unique([trainingSessionId, exerciseId])
  @@index([trainingSessionId])
  @@index([exerciseId])
  @@map("session_exercises")
}

model IntegrationToken {
  id         String    @id @default(cuid())
  athleteId  String
  tokenHash  String
  label      String
  isActive   Boolean   @default(true)
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  athlete Athlete @relation(fields: [athleteId], references: [id])

  @@index([athleteId])
  @@index([isActive])
  @@map("integration_tokens")
}

model TechnicalEvaluation {
  id         String   @id @default(cuid())
  athleteId  String
  microcycle String
  date       DateTime @db.Date
  technique  Int
  tactical   Int
  physical   Int
  mental     Int
  attitude   Int
  notes      String?
  actorId    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  athlete Athlete @relation(fields: [athleteId], references: [id])

  @@unique([athleteId, microcycle])
  @@index([athleteId])
  @@index([date])
  @@map("technical_evaluations")
}

model InjuryProtocol {
  id           String      @id @default(cuid())
  name         String
  structure    String
  grade        InjuryGrade
  steps        Json        @default("[]")
  source       String?
  durationDays Int         @default(0)
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  medicalRecords MedicalRecord[]
  returnToPlay   ReturnToPlay[]

  @@index([structure])
  @@index([isActive])
  @@map("injury_protocols")
}

model MedicalRecord {
  id               String          @id @default(cuid())
  athleteId        String
  protocolId       String?
  occurredAt       DateTime        @db.Date
  structure        String
  grade            InjuryGrade
  mechanism        InjuryMechanism @default(UNKNOWN)
  /// AES-256 encrypted via pgcrypto — never read raw; use decryptField()
  clinicalNotes    Bytes?
  /// AES-256 encrypted via pgcrypto — never read raw; use decryptField()
  diagnosis        Bytes?
  /// AES-256 encrypted via pgcrypto — never read raw; use decryptField()
  treatmentDetails Bytes?
  createdBy        String
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  athlete      Athlete         @relation(fields: [athleteId], references: [id])
  protocol     InjuryProtocol? @relation(fields: [protocolId], references: [id])
  returnToPlay ReturnToPlay[]

  @@index([athleteId])
  @@index([occurredAt])
  @@index([grade])
  @@map("medical_records")
}

model ReturnToPlay {
  id              String    @id @default(cuid())
  athleteId       String    @unique
  status          RtpStatus @default(AFASTADO)
  medicalRecordId String?
  protocolId      String?
  clearedAt       DateTime?
  clearedBy       String?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  athlete       Athlete         @relation(fields: [athleteId], references: [id])
  medicalRecord MedicalRecord?  @relation(fields: [medicalRecordId], references: [id])
  protocol      InjuryProtocol? @relation(fields: [protocolId], references: [id])

  @@index([status])
  @@map("return_to_play")
}

model DataAccessLog {
  id         String   @id @default(cuid())
  actorId    String
  entityId   String
  entityType String   @default("MedicalRecord")
  action     String
  fieldsRead String[]
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([actorId])
  @@index([entityId])
  @@map("data_access_log")
}

model CreditorDisclosure {
  id           String   @id @default(cuid())
  creditorName String
  description  String?
  amountCents  Int
  dueDate      DateTime @db.Date
  /// PENDING | SETTLED | DISPUTED
  status       String   @default("PENDING")
  registeredBy String
  registeredAt DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([dueDate])
  @@index([status])
  @@map("creditor_disclosures")
}

model FieldAccessLog {
  id              String   @id @default(cuid())
  eventId         String?
  scannedBy       String
  payload         String
  isValid         Boolean
  rejectionReason String?
  idempotencyKey  String?  @unique
  scannedAt       DateTime @default(now())
  createdAt       DateTime @default(now())

  @@map("field_access_logs")
}

model PhysioClubAccess {
  id        String   @id @default(cuid())
  userId    String
  clubId    String
  isActive  Boolean  @default(true)
  grantedAt DateTime @default(now())
  grantedBy String

  user User @relation(fields: [userId], references: [id])
  club Club @relation(fields: [clubId], references: [id])

  @@unique([userId, clubId])
  @@index([userId])
  @@index([clubId])
  @@map("physio_club_access")
}

model Event {
  id             String      @id @default(cuid())
  opponent       String
  eventDate      DateTime
  venue          String
  description    String?
  sponsorName    String?
  sponsorLogoUrl String?
  sponsorCtaUrl  String?
  status         EventStatus @default(SCHEDULED)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  sectors   EventSector[]
  tickets   Ticket[]
  posSales  PosSale[]
  checklist GameChecklist[]

  @@index([eventDate])
  @@index([status])
  @@map("events")
}

model EventSector {
  id         String   @id @default(cuid())
  eventId    String
  name       String
  capacity   Int
  sold       Int      @default(0)
  priceCents Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  event   Event    @relation(fields: [eventId], references: [id])
  tickets Ticket[]

  @@index([eventId])
  @@map("event_sectors")
}

model Ticket {
  id          String       @id @default(cuid())
  eventId     String
  sectorId    String
  fanEmail    String
  fanName     String
  status      TicketStatus @default(PENDING)
  checkedIn   Boolean      @default(false)
  checkedInAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  event  Event       @relation(fields: [eventId], references: [id])
  sector EventSector @relation(fields: [sectorId], references: [id])

  @@unique([fanEmail, eventId, sectorId])
  @@index([eventId])
  @@index([sectorId])
  @@index([status])
  @@map("tickets")
}

model FanProfile {
  id              String   @id @default(cuid())
  name            String
  email           String   @unique
  phone           String?
  totalSpentCents Int      @default(0)
  eventIds        String[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([email])
  @@map("fan_profiles")
}

model PosSale {
  id            String   @id @default(cuid())
  eventId       String
  productName   String
  amountCents   Int
  paymentMethod String   @default("CARD")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  event Event @relation(fields: [eventId], references: [id])

  @@index([eventId])
  @@map("pos_sales")
}

model GameChecklist {
  id          String    @id @default(cuid())
  eventId     String
  category    String
  item        String
  completed   Boolean   @default(false)
  completedBy String?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  event Event @relation(fields: [eventId], references: [id])

  @@index([eventId])
  @@map("game_checklists")
}
