# ─── Database ──────────────────────────────────────────────────────────────────
# Development (Docker, no TLS required):
DATABASE_URL="postgresql://clubos:clubos@localhost:5432/clubos_dev?schema=public"

# Production — verify-full + sslrootcert:
# Encrypts the channel AND authenticates the server certificate.
# Download the CA bundle from your managed DB provider and set the path below:
#   RDS:      https://truststore.pki.rds.amazonaws.com/global/global-bundle.pem
#   Supabase: Settings → Database → SSL certificate → Download
#   Neon:     https://neon.tech/docs/connect/connect-securely
#   Cloud SQL: https://cloud.google.com/sql/docs/postgres/connect-auth-proxy
#
# DATABASE_URL="postgresql://user:pass@host:5432/clubos_prod?schema=public&sslmode=verify-full&sslrootcert=/etc/ssl/certs/ca-certificates.crt"
#
# When a provider-specific CA bundle is not available, verify-ca is acceptable:
# DATABASE_URL="postgresql://user:pass@host:5432/clubos_prod?schema=public&sslmode=verify-ca"
#
# Accepted sslmode values in production: verify-ca | verify-full (+ sslrootcert)
# sslmode=require is FORBIDDEN in production — it encrypts the channel but does
# NOT authenticate the server certificate (MITM risk).
# The startup validator (src/lib/env.ts) will crash the process if sslmode is missing,
# set to "disable"/"prefer"/"allow"/"require", or if sslmode=verify-full lacks sslrootcert.

# ─── Redis ─────────────────────────────────────────────────────────────────────
# Development (no TLS or auth required — Docker default):
REDIS_URL=redis://localhost:6379

# Production — TLS + password:
# The rediss:// scheme enables TLS automatically in ioredis.
# The password is placed between the first colon and the @ symbol:
#   rediss://:YOUR_STRONG_PASSWORD@host:6380
#
# Managed Redis providers:
#   Upstash:      Connection string shown in the console (rediss:// by default)
#   Redis Cloud:  Endpoint → Enable TLS → copy the rediss:// URL
#   ElastiCache:  Enable "In-transit encryption" + AUTH token; use port 6380
#   Render:       Redis instance → Connect → Internal URL (rediss://)
#
# REDIS_URL="rediss://:CHANGE_ME_STRONG_PASSWORD@host:6380"
#
# Accepted schemes in production: rediss:// with a non-empty password (MANDATORY)
# redis:// is FORBIDDEN in production — it transmits data in cleartext and allows
# unauthenticated access to refresh tokens, rate-limit buckets, and BullMQ job data.
# The startup validator (src/lib/env.ts) will crash the process if the scheme is
# not rediss:// or if no password is present when NODE_ENV=production.

# ─── Auth ──────────────────────────────────────────────────────────────────────
# Must be at least 32 characters each. Generate with: openssl rand -base64 32
JWT_SECRET=change-me-min-32-chars-in-production
JWT_REFRESH_SECRET=change-me-min-32-chars-in-production

# ─── Encryption ────────────────────────────────────────────────────────────────
# AES-256 symmetric key for CPF/phone encryption at rest (pgcrypto).
# Must be at least 32 characters. Generate with: openssl rand -base64 32
# CRITICAL: Store this separately from database backups (e.g. AWS Secrets Manager).
# Key rotation requires re-encrypting all member rows — see scripts/migrate-encrypt-members.ts.
MEMBER_ENCRYPTION_KEY=change-me-generate-with-openssl-rand-base64-32

# ─── Payment Gateway — Asaas (primary) ────────────────────────────────────────
# Obtain from the Asaas dashboard under API settings:
#   Production: https://www.asaas.com/config/index
#   Sandbox:    https://sandbox.asaas.com/config/index
# The sandbox is used automatically when NODE_ENV != "production".
ASAAS_API_KEY=your-asaas-api-key
ASAAS_WEBHOOK_SECRET=your-asaas-webhook-secret

# ─── Payment Gateway — Pagarme ──
# Obtain from the Pagarme dashboard: https://dashboard.pagar.me
# Both vars must be set to activate the gateway; omitting either disables it.
# The sandbox is used automatically when NODE_ENV != "production".
# PAGARME_API_KEY=ak_live_xxxxxxxxxxxxxxxxxxxx
# PAGARME_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx_at_least_32_chars

# ─── Storage ───────────────────────────────────────────────────────────────────
# Absolute path where uploaded files (logos, etc.) are stored on disk.
# Defaults to <cwd>/uploads when not set.
# In production use a persistent volume or object storage mount.
UPLOAD_DIR=/var/data/clubos/uploads

# Public base URL prepended to all stored asset paths returned by the API.
# Set to your CDN or reverse-proxy origin in production so that clients
# receive a fully qualified URL without hitting the API server directly.
# Defaults to http://localhost:<PORT> in development.
STORAGE_BASE_URL=https://api.clubos.com.br

# ─── App / Networking ──────────────────────────────────────────────────────────
PORT=3001
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# ─── WhatsApp Provider ─────────────────────────────────────────────────────────
# Which provider to use. Supported values: "zapi" | "evolution"
# Defaults to "zapi" if not set.
WHATSAPP_PROVIDER=zapi

# Z-API (https://developer.z-api.io)
# Obtain from the Z-API dashboard after creating an instance.
# instanceId and token are shown on the instance detail page.
# clientToken is the security token used to validate webhook requests.
ZAPI_INSTANCE_ID=your-zapi-instance-id
ZAPI_TOKEN=your-zapi-token
ZAPI_CLIENT_TOKEN=your-zapi-client-token

# Evolution API (self-hosted or cloud: https://evolution-api.com)
# Only required when WHATSAPP_PROVIDER=evolution.
EVOLUTION_API_URL=https://your-evolution-instance.com
EVOLUTION_API_KEY=your-evolution-api-key
EVOLUTION_INSTANCE_NAME=clubos

# ─── CORS — Allowed Origins ────────────────────────────────────────────
# CORS allow-list for cross-origin browser requests.
# In production, only these origins may send credentialled requests to the API.
# Rules enforced by the startup validator (src/lib/env.ts):
#   - MUST be set and non-empty when NODE_ENV=production.
#   - Every origin MUST use https:// — http:// is forbidden.
#     (The application uses httpOnly cookies which browsers only transmit over
#      secure connections; an http:// origin would silently break auth.)
#   - Multiple origins are comma-separated; surrounding spaces are trimmed.
#   - The process will crash on startup if any rule is violated.
#
# Production example (two origins):
#   ALLOWED_ORIGINS=https://app.clubos.com.br,https://clubos.com.br
#
# Development: this variable is optional. All origins are allowed locally
# regardless of its value, so local Next.js dev servers (any port) and API
# clients (Insomnia, Postman) work without additional configuration.
NEXT_PUBLIC_DOMAIN=app.clubos.com.br
NEXT_PUBLIC_API_URL=https://api.clubos.com.br
ALLOWED_ORIGINS=https://app.clubos.com.br

# ─── Observability ─────────────────────────────────────────────────────────────
# Obtain DSN from Sentry project settings: https://sentry.io/settings/
# Leave blank to disable Sentry (acceptable in development and test environments).
SENTRY_DSN=

# ─── Testing ───────────────────────────────────────────────────────────────────
# These values are hardcoded in the CI workflow and only used in test runs.
# DATABASE_URL=postgresql://clubos:clubos@localhost:5432/clubos_test
# REDIS_URL=redis://localhost:6379
# JWT_SECRET=ci-test-secret-access-32chars-min!
# JWT_REFRESH_SECRET=ci-test-secret-refresh-32chars-min!
# MEMBER_ENCRYPTION_KEY=ci-test-encryption-key-32chars-xxx
# ASAAS_API_KEY=ci-fake-asaas-key
# ASAAS_WEBHOOK_SECRET=ci-fake-webhook-secret

# ─── Payment Gateway — Stripe (tertiary, opt-in) ──────────────────────────────
# Set STRIPE_ENABLED=true to activate Stripe as a tertiary fallback gateway.
# Both STRIPE_SECRET_KEY and STRIPE_WEBHOOK_SECRET must be set when enabled;
# missing either with STRIPE_ENABLED=true will cause a loud startup failure.
# Obtain from the Stripe dashboard: https://dashboard.stripe.com/apikeys
# The sandbox is used automatically when NODE_ENV != "production" (use sk_test_ keys).
# STRIPE_ENABLED=false
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Member Digital Card ──────────────────────────────────────────────────────
MEMBER_CARD_SECRET=change-me-generate-with-openssl-rand-base64-32

# ─── Parental Consent ──────────────────────────────────────────────────────────
# HMAC-SHA256 key for signing parental consent tokens issued by POST /api/public/tryout-consent.
# Must be at least 32 characters. Generate with: openssl rand -base64 32
# CRITICAL: Must match CONSENT_HMAC_SECRET in apps/web/.env for Next.js
#           /api/peneiras token verification to work.
# CRITICAL: Must be unique per environment (dev/staging/prod must not share this key).
CONSENT_HMAC_SECRET=change-me-generate-with-openssl-rand-base64-32

// # ─── Field Access QR Code ──────────────────────────────────────────────────
// # HMAC-SHA256 key for signing and verifying QR Code access tokens.
// # Must be at least 32 characters. Generate with: openssl rand -base64 32
// # CRITICAL: Must be unique per environment (dev/staging/prod must not share this key).
ACCESS_QR_SECRET=change-me-generate-with-openssl-rand-base64-32